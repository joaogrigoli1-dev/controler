# =============================================================================
# controler — Variáveis de Ambiente
# =============================================================================
# Secrets marcados com [SSM] são carregados automaticamente do AWS SSM
# Parameter Store em produção. Em dev local, defina aqui ou via Coolify.
# =============================================================================

# =============================================================================
# SERVIDOR
# =============================================================================
PORT=3001
HOST=127.0.0.1

# =============================================================================
# AUTENTICAÇÃO BÁSICA (opcional — deixe vazio para desabilitar)
# =============================================================================

# [SSM: /controler/basic_auth_user] (ou injete via Coolify)
BASIC_AUTH_USER=

# [SSM: /controler/basic_auth_pass] (ou injete via Coolify)
BASIC_AUTH_PASS=

# =============================================================================
# COOLIFY
# =============================================================================
COOLIFY_URL=http://62.72.63.18:8000

# [SSM: /controler/coolify_token]
# Token da API do Coolify para deploys e consultas de serviços.
COOLIFY_TOKEN=CHANGE_ME

# =============================================================================
# OPENCLAW / BRIDGE
# =============================================================================
OPENCLAW_BRIDGE_URL=https://openclaw.controler.net.br
OPENCLAW_BRIDGE_INTERNAL_URL=http://openclaw:18790

# [SSM: /openclaws/controler/gateway_token]
# Token de autenticação do agente OpenClaws do controler.
OPENCLAW_TOKEN=CHANGE_ME

# =============================================================================
# AWS SSM (credenciais para leitura dos secrets acima)
# =============================================================================
# Em produção, usar IAM Role do container — não defina aqui.
# Em dev local, configurar via: aws configure --profile cowork-admin
AWS_REGION=us-east-1
# AWS_SSM_ENABLED=true   # defina como "false" para desabilitar SSM em dev

# =============================================================================
# OUTROS (não-sensíveis)
# =============================================================================
# Caminho do CLI do Claude para execução de tarefas de IA
CLAUDE_CLI_PATH=/usr/local/bin/claude
