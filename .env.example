# ─────────────────────────────────────────────────────────
# Controler v4 — Environment Variables
# Em produção tudo vem do AWS SSM (/controler/*)
# Em dev usa este arquivo (copiado para .env)
# ─────────────────────────────────────────────────────────

# Database
DATABASE_URL=postgresql://controler:controler@localhost:5432/controler?schema=public
REDIS_URL=redis://localhost:6379

# JWT
JWT_ACCESS_SECRET=change-me-in-prod-min-32-chars-long-secret
JWT_REFRESH_SECRET=change-me-too-in-prod-min-32-chars-long
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# AWS (usa profile cowork-admin em dev; IAM role em prod)
AWS_REGION=us-east-1
AWS_PROFILE=cowork-admin

# Hostinger
HOSTINGER_API_TOKEN=
HOSTINGER_API_BASE_URL=https://developers.hostinger.com/api/vps/v1
SRV1_VPS_ID=1379597
FISIOMT_VPS_ID=1514729

# Coolify
COOLIFY_BASE_URL=https://coolify.controler.net.br
COOLIFY_TOKEN=
CONTROLER_APP_UUID=hksw4kg8owgs0wwg0o8k4kk0
CONTROLER_V4_APP_UUID=

# SSH (HestiaCP até MCP estar pronto)
# Precedência em runtime: env → SSM (/shared/srv1/*) → default.
# PORTA REAL do SRV1 é 47391 (fonte da verdade = SSM /shared/srv1/port); 22 é só fallback.
SRV1_SSH_HOST=62.72.63.18
SRV1_SSH_PORT=47391
SRV1_SSH_USER=root
SRV1_SSH_KEY_PATH=/root/.ssh/id_ed25519
FISIOMT_SSH_HOST=
FISIOMT_SSH_USER=root

# Z-API (OTP WhatsApp)
ZAPI_INSTANCE_ID=
ZAPI_TOKEN=
ZAPI_CLIENT_TOKEN=
ZAPI_BASE_URL=https://api.z-api.io

# Infobip (SMS críticos)
INFOBIP_API_KEY=
INFOBIP_BASE_URL=

# Cloudflare
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=

# Alertas (13 dígitos: 55 + DDD 65 + 9 + 8 dígitos)
ALERT_PHONE_DEFAULT=5565984665555

# App
PORT=4000
WEB_PORT=3000
NODE_ENV=development
LOG_LEVEL=info

# Frontend (Next.js)
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_WS_URL=ws://localhost:4000
